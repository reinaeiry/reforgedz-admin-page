# Backend (Node) configuration
PORT=3000
DATA_DIR=data

# Admin login for the website
ADMIN_USER=admin
ADMIN_PASS=change-me

# Token signing secret (set to a long random string in production)
TOKEN_SECRET=dev-token-secret-change-me

# Ingest authentication mapping: "serverId=serverKey,serverId2=serverKey2"
# Your current dev server key:
INGEST_KEYS=reforgedz-dev-eu-1=reforgedz-dev-eu-1-secret
